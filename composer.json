{
    "name": "trustbird/filament-trustbird",
    "description": "Optional Filament admin panel for Trustbird's Laravel core package.",
    "license": "MIT",
    "type": "library",
    "keywords": ["trustbird", "filament", "laravel", "isms", "grc", "compliance"],
    "homepage": "https://github.com/Trustbird/filament-trustbird",
    "support": {
        "issues": "https://github.com/Trustbird/filament-trustbird/issues",
        "source": "https://github.com/Trustbird/filament-trustbird"
    },
    "require": {
        "php": "^8.4",
        "composer-runtime-api": "^2.1",
        "ext-intl": "*",
        "filament/filament": "^4.0",
        "spatie/laravel-package-tools": "^1.92",
        "trustbird/laravel-trustbird": "^0.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "1.29.3",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Trustbird\\Filament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Trustbird\\Filament\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Trustbird\\Filament\\FilamentTrustbirdServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "format": "pint",
        "test": "pest --parallel",
        "test:coverage": "pest --coverage --min=100",
        "test:types": "phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
